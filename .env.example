# Herald - Environment Variables
# Copy this file to .env and fill in your values

# Required: Anthropic API key (get one at console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required: Google OAuth credentials
# Create at console.cloud.google.com > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Required: Change this to a long random string in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-replace-with-random-string

# Google OAuth redirect URI
# Local development:
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
# Production (replace with your Railway/Render URL):
# GOOGLE_REDIRECT_URI=https://your-app.railway.app/auth/callback

# Optional settings
DEBUG=false
PORT=8000
HOST=0.0.0.0
MAX_EMAILS_TO_PROCESS=100
